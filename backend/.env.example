LOGS_DATABASE_URL=mysql+pymysql://root:@localhost:3306/gobus_chatbot_logs
DATABASE_URL=mysql+pymysql://root:@localhost:3306/gobus_chatbot
OPENAI_API_KEY=your-openai-api-key-here
# Optional: custom OpenAI-compatible endpoint (leave blank for OpenAI default)
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720
ADMIN_EMAIL=admin@gobus.local
ADMIN_PASSWORD=admin123
WEBSITE_DATA_PATH=../Website data
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- CRM / ticketing email (SMTP) ---
# Leave SMTP_ENABLED=false to run in mock mode (emails are logged, not sent).
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=GoBus Support <no-reply@gobus.local>
SMTP_USE_TLS=true
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
TICKETING_MODEL=gpt-4o-mini
